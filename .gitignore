# 자동 기록 로그 (질문·세션 hook 기록은 커밋하지 않음 — 폴더 구조만 유지)
logs/*.jsonl
logs/sessions/
logs/sessions.log

# 의존성 (하위 backend/ · frontend/ .gitignore 가 1차로 처리, 안전망)
vendor/
node_modules/

# 환경설정·비밀값 (절대 커밋 금지)
.env
.env.*
!.env.example

# 빌드 산출물
dist/
/build/
backend/public/build/
backend/public/hot
backend/public/storage

# Laravel 런타임 캐시/로그
backend/storage/framework/cache/data/*
backend/storage/logs/*.log
backend/bootstrap/cache/*.php

# OS·에디터
.DS_Store
Thumbs.db
.idea/
.vscode/

# 임시 디버그 스크립트 (공개 제외)
/backend/test_*.php

# 직원 간 기술 핸드오프 문서 — 포폴 공개용이 아니다.
# 실명·공인IP·실계좌·사생활 맥락이 반복해서 유입됐다(2026-07-17 유출 적발).
docs/features/
